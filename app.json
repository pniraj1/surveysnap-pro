{
  "expo": {
    "name": "SurveySnap Pro",
    "slug": "surveysnap-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06080F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.surveysnap.pro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06080F"
      },
      "package": "com.surveysnap.pro",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SurveySnap Pro needs camera access to capture survey photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SurveySnap Pro uses your location to geotag survey photos.",
          "locationWhenInUsePermission": "SurveySnap Pro uses your location to geotag survey photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SurveySnap Pro to access your photos.",
          "savePhotosPermission": "Allow SurveySnap Pro to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "react-native-google-mobile-ads"
    ],
    "extra": {
      "eas": {}
    }
  }
}
